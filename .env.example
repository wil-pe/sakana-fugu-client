# ─────────────────────────────────────────────────────────────
#  Configuration du client Fugu — copiez ce fichier en « .env »
#  puis renseignez votre clé.   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Votre clé API Sakana (obligatoire si vous ne la saisissez pas dans l'UI)
# Récupérez-la sur https://console.sakana.ai
SAKANA_API_KEY=

# Port du serveur local (optionnel, défaut : 3000)
# PORT=3000

# URL de base de l'API (optionnel, ne pas changer sauf besoin spécifique)
# SAKANA_BASE_URL=https://api.sakana.ai/v1
